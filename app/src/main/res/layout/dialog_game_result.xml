<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#2E7D32"
    android:elevation="10dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏆 РЕЗУЛЬТАТ ИГРЫ 🏆"
        android:textSize="22sp"
        android:textColor="#FFD700"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        android:layout_gravity="center" />

    <!-- Победитель -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#4CAF50"
        android:padding="15dp"
        android:layout_marginBottom="10dp">

        <ImageView
            android:id="@+id/ivWinnerAvatar"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/avatar1" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="15dp">

            <TextView
                android:id="@+id/tvWinnerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Победитель"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWinnerScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="24sp"
                android:textColor="#FFD700"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆"
            android:textSize="30sp" />
    </LinearLayout>

    <!-- Проигравший (скрывается при ничьей) -->
    <LinearLayout
        android:id="@+id/loserLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#333333"
        android:padding="15dp"
        android:layout_marginBottom="15dp">

        <ImageView
            android:id="@+id/ivLoserAvatar"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/avatar2" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="15dp">

            <TextView
                android:id="@+id/tvLoserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Проигравший"
                android:textSize="16sp"
                android:textColor="#CCCCCC" />

            <TextView
                android:id="@+id/tvLoserScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="20sp"
                android:textColor="#FF9800" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="😢"
            android:textSize="30sp" />
    </LinearLayout>

    <!-- Информация о режиме игры -->
    <TextView
        android:id="@+id/tvGameMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Режим: Два игрока"
        android:textSize="14sp"
        android:textColor="#CCCCCC"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- Кнопки действий -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnNewGame"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="🔄 Сыграть ещё"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnMainMenu"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="🏠 Главное меню"
            android:backgroundTint="#FF5722"
            android:textColor="@android:color/white" />

    </LinearLayout>

</LinearLayout>